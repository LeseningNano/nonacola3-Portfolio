generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Video {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String
  embedUrl    String
  thumbnail   String?
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model HeroVideo {
  id        String   @id @default("singleton")
  blobUrl   String
  updatedAt DateTime @updatedAt
}
