generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Video {
  id          String    @id @default(cuid())
  title       String
  description String?
  summary     String?
  category    String
  embedUrl    String
  thumbnail   String?
  featured    Boolean   @default(false)
  order       Int       @default(0)
  date        DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([order])
  @@index([order, createdAt])
  @@index([category])
}

model HeroVideo {
  id        String   @id @default("singleton")
  blobUrl   String
  updatedAt DateTime @updatedAt
}

model Showreel {
  id          String   @id @default("singleton")
  showreelUrl String   @default("")
  videoType   String   @default("url") // "url" or "upload"
  updatedAt   DateTime @updatedAt
}

model Post {
  id        String   @id @default(cuid())
  title     String?
  body      String
  tag       String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}
